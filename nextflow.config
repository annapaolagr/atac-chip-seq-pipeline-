params {
    input  = "data/*_{R1,R2,1,2}.fastq.gz"
    outdir = "results"
}

profiles {
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // QUESTA RIGA È FONDAMENTALE: scavalca l'errore loop device
        singularity.runOptions = '--sandbox'
    }
}

process {
    // Definiamo i container qui per essere sicuri che li legga
    withName: 'FASTQC' {
        container = 'https://depot.galaxyproject.org/singularity/fastqc:0.11.9--0'
    }
    withName: 'TRIMGALORE' {
        container = 'https://depot.galaxyproject.org/singularity/trim-galore:0.6.6--0'
    }
}
