// 1. Carica la configurazione dei genomi (AWS iGenomes)
includeConfig 'conf/igenomes.config'

params {
    input         = "data/*_R{1,2}*.fastq.gz"
    outdir        = "results"
    // Genoma di default se l'utente non specifica --genome
    genome        = 'hg38' 
}

profiles {
    docker {
        docker.enabled         = true
        // Evita problemi di permessi con i file creati da Docker
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
}

process {
    // Configurazione specifica per ogni processo
    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
    }

    withName: TRIMGALORE {
        cpus   = 2
        memory = '4 GB'
    }

    withName: BOWTIE2 {
        cpus   = 6
        memory = '16 GB'
    }

    withName: SAMTOOLS_SORT {
        cpus   = 4
        memory = '8 GB'
    }
}
