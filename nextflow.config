params {
    reads  = "data/*_R{1,2}.fastq.gz"
    outdir = "results"
}

profiles {
    // PROFILO DOCKER
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
    }

    // PROFILO SINGULARITY
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // Aggiungi questa riga per evitare l'errore dei "loop devices" che avevi prima
        singularity.engineOptions = '--userns' 
    }
}

process {
    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
    }
}
