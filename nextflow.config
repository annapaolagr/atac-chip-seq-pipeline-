// 1. FONDAMENTALE: Aggiunto plugin per leggere da S3 (iGenomes)
plugins {
    id 'nf-amazon'
}

aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

params {
    input            = "samplesheet.csv" // Assicurati che nel comando scrivi .csv e non .cvs
    protocol         = "chip" 
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes' // Rimosso lo slash finale per evitare // nel percorso
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}

process.shell = ['/bin/bash', '-euo', 'pipefail']
includeConfig 'conf/igenomes.config'

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

executor {
    queueSize = 4 
}

process {
    cpus   = 2
    memory = '4 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/01_fastqc", mode: params.publish_dir_mode ]
    }

    withName: TRIMGALORE {
        cpus   = 4
        memory = '8 GB'
        publishDir = [ path: "${params.outdir}/02_trimmed", mode: params.publish_dir_mode ]
    }

    withName: BOWTIE2 {
        cpus   = 12
        memory = '32 GB'
        ext.args   = '--very-sensitive -X 2000 --no-mixed --no-discordant'
        publishDir = [ path: "${params.outdir}/03_aligned_raw", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_SORT {
        cpus   = 6
        memory = '20 GB'
        ext.args   = '-m 800M' 
        publishDir = [ path: "${params.outdir}/03_aligned_sorted", mode: params.publish_dir_mode ]
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 2
        memory = '24 GB'
        ext.args   = '--REMOVE_DUPLICATES true --ASSUME_SORTED true --VALIDATION_STRINGENCY LENIENT --CREATE_INDEX true'
        publishDir = [ path: "${params.outdir}/04_deduplicated", mode: params.publish_dir_mode ]
    }

    withName: MACS3_ATAC {
        cpus   = 4
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/05_peaks/atac", mode: params.publish_dir_mode ]
    }

   withName: MACS3_CHIP_NARROW {
        cpus   = 4
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/05_peaks/chip/narrow", mode: params.publish_dir_mode ]
    }

    withName: MACS3_CHIP_BROAD {
        cpus   = 4
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/05_peaks/chip/broad", mode: params.publish_dir_mode ]
    }
}
