params {
    reads  = "data/*_R{1,2}.fastq.gz"
    outdir = "results"
}

profiles {
    // PROFILO DOCKER
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
    }

    // PROFILO SINGULARITY
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        sandbox    = true 
    }
}

process {
    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
    }
}
