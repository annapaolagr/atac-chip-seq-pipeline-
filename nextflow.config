params {
    input  = "data/*_R{1,2}.fastq.gz"
    outdir = "results"
}

profiles {
    docker {
        docker.enabled         = true
        
    }
singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
}

process {
    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
    }
}
