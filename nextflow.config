// 1. OTTIMIZZAZIONE DOWNLOAD
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

// 2. PARAMETRI GLOBALI
params {
    input            = "data/*_R{1,2}*.fastq.gz"
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes/'
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}

// 3. ROBUSTEZZA
process.shell = ['/bin/bash', '-euo', 'pipefail']
includeConfig 'conf/igenomes.config'

// 4. PROFILI
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

// 5. GESTIONE RISORSE E PARALLELISMO
executor {
    queueSize = 10
}

process {
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/01_fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 8
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/02_trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 12 
        memory = '24 GB'
        // Non pubblichiamo, passa il file raw a Picard
    }

    // --- NUOVI SETTAGGI PICARD ---
    
    withName: PICARD_ADDRG {
        cpus   = 2
        // Picard AddRG ha bisogno di RAM per gestire i buffer di scrittura
        memory = '12 GB'
        // Non pubblichiamo, è uno step intermedio
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 2
        // MarkDuplicates è il processo più critico per la RAM
        // Deve tenere in memoria le coordinate delle reads per il confronto
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/03_deduplicated", mode: 'copy' ]
    }

    withName: SAMTOOLS_SORT {
        cpus   = 8
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/04_final_bam", mode: 'copy' ]
    }
}
