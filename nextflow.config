
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}


params {
    input            = "data/*_R{1,2}*.fastq.gz"
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes/'
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}


process.shell = ['/bin/bash', '-euo', 'pipefail']
includeConfig 'conf/igenomes.config'


profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

executor {
    queueSize = 3
}

process {
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/01_fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 8
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/02_trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 10 
        memory = '20 GB'
    }

    withName: PICARD_ADDRG {
        cpus   = 2
        memory = '12 GB'
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 2
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/03_deduplicated", mode: 'copy' ]
    }

    withName: SAMTOOLS_SORT {
        cpus   = 8
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/04_final_bam", mode: 'copy' ]
    }

    withName: MACS3_ATAC {
        cpus   = 4
        memory = '8 GB'
        publishDir = [ path: "${params.outdir}/05_peaks", mode: 'copy' ]
    }
}
