// 1. IL TRUCCO PER LO SCARICAMENTO VELOCE (Aggiungi questo in cima!)
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

includeConfig 'conf/igenomes.config'

params {
    input         = "data/*_R{1,2}*.fastq.gz"
    outdir        = "results"
    genome        = 'hg38'
    // Permette di usare un indice locale se già presente sul server
    bowtie2_index = null 
}

// 2. Definizione dei profili per la portabilità
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // Rimosso 'sandbox = true' a meno che non sia strettamente necessario, 
        // solitamente causa problemi di permessi su molti cluster.
    }
}

// 3. Gestione Risorse e Pubblicazione Risultati
process {
    // Risorse di default se non specificate sotto
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        // I risultati di FastQC andranno in results/fastqc
        publishDir = [ path: "${params.outdir}/fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 6
        memory = '16 GB'
        // Non pubblichiamo il SAM perché è pesante e temporaneo
    }

    withName: SAMTOOLS_SORT {
        cpus   = 4
        memory = '8 GB'
        // Il BAM finale è il nostro risultato principale
        publishDir = [ path: "${params.outdir}/alignment", mode: 'copy' ]
    }
}
