params {
    input  = "data/*_{R1,R2,1,2}.fastq.gz"
    outdir = "results"
}

profiles {
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // 
        singularity.runOptions = '--bind $PWD'
    }
}

process {
    // Assegniamo risorse standard
    cpus   = 2
    memory = '4 GB'
}
