// 1. OTTIMIZZAZIONE DOWNLOAD
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

// 2. PARAMETRI GLOBALI
params {
    input            = "data/*_R{1,2}*.fastq.gz"
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes/'
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}

// 3. ROBUSTEZZA
process.shell = ['/bin/bash', '-euo', 'pipefail']

includeConfig 'conf/igenomes.config'

// 4. PROFILI (Corretto per evitare errori di parsing)
profiles {
    docker {
        docker.enabled         = true
        // NOTA: Usiamo le virgolette SINGOLE qui, così è più sicuro per Nextflow
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

// 5. Gestione Risorse e Pubblicazione Risultati
process {
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 8
        memory = '18 GB'
        // Non pubblichiamo nulla qui perché il BAM passa via pipe a SAMTOOLS_SORT
    }

    withName: SAMTOOLS_SORT {
        cpus   = 4
        memory = '8 GB'
        publishDir = [ path: "${params.outdir}/alignment", mode: 'copy' ]
    }
}
