// 1. OTTIMIZZAZIONE DOWNLOAD
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

// 2. PARAMETRI GLOBALI
params {
    input            = "data/*_R{1,2}*.fastq.gz"
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes/'
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}

// 3. ROBUSTEZZA (Importante per le pipe!)
// 'pipefail' serve a far fallire il processo se Bowtie2 crasha mentre manda i dati a Samtools
process.shell = ['/bin/bash', '-euo', 'pipefail']

includeConfig 'conf/igenomes.config'

// 4. PROFILI (Docker/Singularity)
profiles {
    docker {
        docker.enabled         = true
        // NOTA: Ho aggiunto il backslash prima di $ per essere sicuri che Linux legga l'ID correttamente
        docker.runOptions      = "-u \$(id -u):\$(id -g)"
        // Abbiamo tolto docker.registry = 'quay.io' per poter usare DockerHub liberamente
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

// 5. Gestione Risorse e Pubblicazione Risultati
process {
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 10 // Aumentato un po' per gestire allineamento + compressione BAM al volo
        memory = '24 GB' 
        // Adesso Bowtie2 produce un file .raw.bam. 
        // Di solito non si pubblica perché pubblicheremo il .sorted.bam dopo.
    }

    withName: SAMTOOLS_SORT {
        cpus   = 6
        memory = '12 GB'
        // Questo è il file finale che vogliamo vedere nella cartella results
        publishDir = [ path: "${params.outdir}/alignment", mode: 'copy' ]
    }
}

// 6. REPORTISTICA
def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html" }// 3. Gestione Risorse e Pubblicazione Risultati
process {
    // Risorse di default se non specificate sotto
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        // I risultati di FastQC andranno in results/fastqc
        publishDir = [ path: "${params.outdir}/fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 8
        memory = '18 GB'
        // Non pubblichiamo il SAM perché è pesante e temporaneo
    }

    withName: SAMTOOLS_SORT {
        cpus   = 4
        memory = '8 GB'
        // Il BAM finale è il nostro risultato principale
        publishDir = [ path: "${params.outdir}/alignment", mode: 'copy' ]
    }
}

// 6. REPORTISTICA (Le tabelle belle che vedi in nf-core)
def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html" }
