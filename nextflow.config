// 1. OTTIMIZZAZIONE DOWNLOAD (Mantieni così, è perfetto per AWS)
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

// 2. PARAMETRI GLOBALI
params {
    input            = "data/*_R{1,2}*.fastq.gz"
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes/'
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}

// 3. ROBUSTEZZA
process.shell = ['/bin/bash', '-euo', 'pipefail']

includeConfig 'conf/igenomes.config'

// 4. PROFILI (Invariati)
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

// 5. GESTIONE RISORSE E PARALLELISMO (Qui cambiamo tutto!)
executor {
    // Permette di far girare più campioni insieme. 
    // Se hai 3 campioni, metti almeno 3 o più.
    queueSize = 10
}

process {
    // Risorse di default basse per i processi piccoli
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/01_fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        // Con 8 CPU e il comando --cores 4, TrimGalore vola
        cpus   = 8
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/02_trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        // Bowtie2 è il cuore del calcolo: diamogli più potenza
        cpus   = 12 
        memory = '24 GB'
        // Non pubblichiamo perché il BAM non è ancora ordinato
    }

    withName: SAMTOOLS_SORT {
        // Aumentiamo la memoria per l'ordinamento (fondamentale per la velocità)
        cpus   = 6
        memory = '12 GB'
        // Non pubblichiamo se passiamo subito a Markdup, altrimenti 'copy'
    }

}
