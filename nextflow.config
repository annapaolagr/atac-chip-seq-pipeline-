// Parametri di default
params {
    input            = "data/*_{R1,R2,1,2}.fastq.gz"
    outdir           = "results"
    publish_dir_mode = 'copy'
    
    // Risorse massime (come in nf-core)
    max_cpus   = 16
    max_memory = '128.GB'
}

profiles {
    // Profilo Docker: per evitare errori di permessi
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        docker.registry        = 'quay.io'
    }

    // Profilo Singularity
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
        // 
        // singularity.runOptions = '-C -e'
    }
}

// Gestione risorse dei processi (stile base.config di nf-core)
process {
    cpus   = { check_max( 2, 'cpus' ) }
    memory = { check_max( 4.GB, 'memory' ) }

    withName: FASTQC {
        cpus   = { check_max( 4, 'cpus' ) }
    }
}

// Funzione di controllo risorse (da nf-core)
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) { return obj }
    }
}
